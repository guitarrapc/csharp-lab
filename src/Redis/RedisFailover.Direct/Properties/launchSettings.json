{
  "profiles": {
    "http": {
      "commandName": "Project",
      "launchBrowser": true,
      "launchUrl": "swagger",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ConnectionStrings__Redis1": "redis-node-5:6379,ssl=false,keepAlive=60,password=bitnami",
        "ConnectionStrings__Redis2": "redis-node-5:6379,ssl=false,keepAlive=60,password=bitnami"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "http://localhost:5052"
    },
    "Container (Dockerfile)": {
      "commandName": "Docker",
      "launchBrowser": true,
      "launchUrl": "{Scheme}://{ServiceHost}:{ServicePort}/swagger",
      "environmentVariables": {
        "ASPNETCORE_HTTP_PORTS": "8080",
        "ConnectionStrings__Redis1": "localhost:6379,ssl=false,keepAlive=60,password=bitnami",
        "ConnectionStrings__Redis2": "localhost:6379,ssl=false,keepAlive=60,password=bitnami"
      },
      "publishAllPorts": true,
      "useSSL": false
    }
  },
  "$schema": "http://json.schemastore.org/launchsettings.json"
}
